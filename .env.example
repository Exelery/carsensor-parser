# Database (backend, worker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cars

# Backend
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
# Внутренний API-ключ: бот обращается к /api/cars без JWT (заголовок X-Internal-API-Key)
INTERNAL_API_KEY=
# Парсинг поиска (бот + админка): DeepSeek API (OpenAI-совместимый)
DEEPSEEK_API_KEY=

# Scraper worker
SCRAPER_INTERVAL_SEC=60

# Frontend (build-time: API URL as seen by browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Telegram bot (работает только через API бэкенда)
TELEGRAM_BOT_TOKEN=
BACKEND_URL=http://backend:8000
INTERNAL_API_KEY=
